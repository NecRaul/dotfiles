#!/bin/sh

process_info=$(
    ps axch -o comm,%cpu:5,rss --sort=-%cpu |
        awk '{
            mem = sprintf("%.0f MiB", $3 / 1024)
            cpu = sprintf("%d%%", $2 + 0.5)
            stats = length(mem) + length(cpu)
            avail = 18 - stats
            cmd = $1
            if (length(cmd) > avail)
                cmd = substr(cmd, 1, avail)
            printf "%s: %s (%s)\n", cmd, mem, cpu
        }' | head -n 9
)

case $BLOCK_BUTTON in
1) notify-send " CPU usage" "$process_info" ;;
2) setsid -f "$TERMINAL" -e btop ;;
3) notify-send " CPU module" "\
- Shows CPU usage.
- Click to show CPU processes.
- Middle click to open btop." ;;
6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

echo "[  CPU: $(top -b -n1 | awk '/Cpu\(s\)/ { printf "%.1f%%", $2 + $4 + $6 }') ]"
