#!/bin/sh

process_info=$(
    ps axch -o comm,%mem:5,rss --sort=-%mem |
        awk '{
            mem = sprintf("%.0f MiB", $3 / 1024)
            ram = sprintf("%d%%", $2 + 0.5)
            stats = length(mem) + length(ram)
            avail = 18 - stats
            cmd = $1
            if (length(cmd) > avail)
                cmd = substr(cmd, 1, avail)
            printf "%s: %s (%s)\n", cmd, mem, ram
        }' | head -n 9
)

case $BLOCK_BUTTON in
1) notify-send " Memory usage" "$process_info" ;;
2) setsid -f "$TERMINAL" -e btop ;;
3) notify-send " Memory module" "\
- Shows memory usage.
- Click to show memory processes.
- Middle click to open btop." ;;
6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

echo "[  RAM: $(free -m | awk '/Mem:/ { printf "%.1f%%", $3 / $2 * 100 }') ]"
