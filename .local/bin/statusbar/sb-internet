#!/bin/sh

# Show wifi σΑ•© and percent strength or σΑΛ· if none.
# Show σΑà¹ if connected to ethernet or σΑà² if none.
# Show σΑ•² if a vpn connection is active

case $BLOCK_BUTTON in
1) "$TERMINAL" -e nmtui && pkill -RTMIN+4 dwmblocks ;;
3) notify-send "σΑ•ü Internet module" "\- Click to connect
σΑ•Σ: wifi disabled
σΑΛ·: no wifi connection
σΑ•©: wifi connection with quality
σΑà²: no ethernet
σΑà¹: ethernet working
σΑ•²: vpn is active
" ;;
6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

# Wifi
if [ "$(cat /sys/class/net/w*/operstate 2>/dev/null)" = 'up' ]; then
    wifi_icon="$(awk '/^\s*w/ { print "σΑ•©", int($3 * 100 / 70) "% " }' /proc/net/wireless)"
elif [ "$(cat /sys/class/net/w*/operstate 2>/dev/null)" = 'down' ]; then
    [ "$(cat /sys/class/net/w*/flags 2>/dev/null)" = '0x1003' ] && wifi_icon="σΑΛ· " || wifi_icon="σΑ•Σ "
fi

# Ethernet
[ "$(cat /sys/class/net/e*/operstate 2>/dev/null)" = 'up' ] && ethernet_icon="σΑà¹" || ethernet_icon="σΑà²"

# VPN
nmcli -t -f TYPE,STATE connection show --active | awk -F: '
$1 == "vpn" || $1 == "wireguard" { found=1 }
END { exit !found }
' && vpn_icon=" σΑ•² $(curl -4 -s https://api.ipify.org 2>/dev/null)"

printf "[ %s%s%s ]\n" "$wifi_icon" "$ethernet_icon" "$vpn_icon"
