#!/bin/sh

filter() {
    awk '
        /^ERROR/ { exit }
        /^volume:/ { next }
        /\[paused\]/ { next }
        /\[playing\]/ { next }
        { lines[++n] = $0 }

        END {
            if (n == 0)
                exit

            printf "[ "
            for (i = 1; i <= n; i++)
                printf " %s", lines[i]
            printf " ]\n"
        }
    '
}

case $BLOCK_BUTTON in
1) setsid -f "$TERMINAL" -e ncmpcpp ;;
2) mpc toggle | filter ;;
3) notify-send " Music module" "\- Shows mpd song playing.
- Left click opens ncmpcpp.
- Middle click toggles play.
- Scroll changes track." ;;
4) mpc prev ;;
5) mpc next ;;
6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

mpc status | filter
