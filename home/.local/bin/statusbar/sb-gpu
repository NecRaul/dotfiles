#!/bin/sh

gpu_json=
process_info=

get_gpu_json() {
    [ -n "$gpu_json" ] || gpu_json=$(nvtop -s)
    printf '%s\n' "$gpu_json"
}

get_process_info() {
    [ -n "$process_info" ] || process_info=$(
        get_gpu_json |
            jq -r '
            .[0].processes
            | sort_by(.gpu_mem_bytes_alloc | tonumber)
            | reverse
            | .[]
            | (.cmdline | split(" ")[0] | split("/")[-1]) as $cmd
            | ((.gpu_mem_bytes_alloc | tonumber / 1024 / 1024 | floor | tostring) + " MiB") as $mem
            | .gpu_mem_usage as $usage
            | (($mem | length) + ($usage | length)) as $stats
            | (18 - $stats) as $avail
            | (
                if ($cmd | length) > $avail
                then $cmd[:$avail]
                else $cmd
                end
            ) as $cmd
            | "\($cmd): \($mem) (\($usage))"
        '
    )
    printf '%s\n' "$process_info"
}

case $BLOCK_BUTTON in
1) notify-send " GPU usage" "$(get_process_info)" ;;
2) setsid -f "$TERMINAL" -e nvtop ;;
3) notify-send " GPU module" "\- Shows GPU VRAM usage.
- Click to show GPU processes.
- Middle click to open nvtop." ;;
6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

read -r used total <<EOF
$(get_gpu_json | jq -r '.[0] | [.mem_used, .mem_total] | @tsv')
EOF

printf '[  GPU: %.1f%% ]\n' "$(awk "BEGIN { print $used * 100 / $total }")"
