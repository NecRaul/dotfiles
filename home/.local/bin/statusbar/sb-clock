#!/bin/sh

calendar() {
    day=$(date +'%e' | tr -d ' ')
    cal -m | sed -E "s/(^|[[:space:]])($day)([[:space:]]|$)/\1<span foreground='red'><b>\2<\/b><\/span>\3/g"
}

case $BLOCK_BUTTON in
1) notify-send "      Calendar" "$(calendar)" ;;
3) notify-send " Time/date module" "\- Left click to show the month via \`cal\`" ;;
6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

date "+[  %a, %B %d  %I:%M%p ] "
