# shellcheck shell=bash

# General/convenience
alias sudo="sudo "
alias vim="nvim"
alias mkdir="mkdir -p"
alias diff="diff --color=auto"

# Coreutils replacements
alias ls="eza --color=auto --icons=auto --no-quotes --group-directories-first -x"
alias ld="eza --color=auto --icons=auto --no-quotes --group-directories-first -xa | grep \"^\.\""
alias la="eza --color=auto --icons=auto --no-quotes --group-directories-first -xa"
alias ll="eza --color=auto --icons=auto --no-quotes --group-directories-first -xlg --git"
alias lt="eza --color=auto --icons=auto --no-quotes --group-directories-first -xTg -L 3"
alias lla="eza --color=auto --icons=auto --no-quotes --group-directories-first -xalg --git"
alias llt="eza --color=auto --icons=auto --no-quotes --group-directories-first -xlTg --git -I \".git\" -L 3"
alias lta="eza --color=auto --icons=auto --no-quotes --group-directories-first -xaTg -I \".git\" -L 3"
alias llta="eza --color=auto --icons=auto --no-quotes --group-directories-first -xalTg --git -I \".git\" -L 3"
alias cat="bat --color=auto --theme base16-256"
alias grep="rg"

# Wrapper scripts
alias lf="lfub"
alias ncmpcpp="ncmpcpp-art"
alias nsxiv="nsxiv-rifle"
